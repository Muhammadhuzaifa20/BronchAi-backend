# ============================================================
# BronchAI ML Backend — Environment Variables
# Set these in Railway Dashboard → Variables
# ============================================================

# Hugging Face model repository (format: username/repo-name)
HF_REPO_ID=muhammadhuzaifa2003/New_Model

# Allowed frontend origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://bronchai.netlify.app

# Optional: Model cache directory (Railway uses ephemeral storage)
MODEL_CACHE_DIR=/tmp/models

# PORT is set automatically by Railway — do NOT set manually
